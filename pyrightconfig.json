    "modules/hmi-application/application",
    "modules/hmi-application/tests",
    "scripts",
    "tests",
    "scripts/testing"
  ],
  "exclude": [
    "**/__pycache__",
    ".agents",
    "build",
    "plugins",
    "tests/reports",
    "third_party"
  ],
  "ignore": [
