      "root": "apps/hmi-app/src",
      "extraPaths": [
        "modules/dxf-geometry/application",
        "modules/hmi-application/application",
        "shared/testing/test-kit/src"
      ]
    },
    {
      "root": "apps/hmi-app/tests",
      "extraPaths": [
        "apps/hmi-app/src",
        "modules/dxf-geometry/application",
        "modules/hmi-application/application",
        "shared/testing/test-kit/src"
      ]
    },
    {
      "root": "modules/dxf-geometry/application",
      "extraPaths": [
        "modules/runtime-execution/application",
        "shared/testing/test-kit/src"
      ]
    },
    {
      "root": "modules/hmi-application/application",
      "extraPaths": [
        "apps/hmi-app/src",
        "modules/dxf-geometry/application",
        "shared/testing/test-kit/src"
      ]
    },
    {
      "root": "modules/hmi-application/tests",
      "extraPaths": [
        "apps/hmi-app/src",
        "modules/dxf-geometry/application",
        "modules/hmi-application/application",
        "shared/testing/test-kit/src"
      ]
    },
    {
      "root": "tests",
      "extraPaths": [
        "apps/hmi-app/src",
        "apps/hmi-app/src/hmi_client",
        "apps/planner-cli/tools",
        "modules/dxf-geometry/application",
        "modules/hmi-application/application",
        "modules/runtime-execution/application",
        "tests/e2e/hardware-in-loop",
        "tests/performance",
        "shared/testing/test-kit/src"
      ]
    },
    {
      "root": "scripts",
