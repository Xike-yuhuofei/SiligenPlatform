{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://siligensuite.local/contracts/engineering/v1/simulation-input.schema.json",
  "title": "Simulation Input",
  "description": "Canonical JSON directly consumable by runtime simulation loader or runtime bridge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestep_seconds",
    "max_simulation_time_seconds",
    "max_velocity",
    "max_acceleration",
    "segments",
    "io_delays",
    "triggers",
    "valve"
  ],
  "$defs": {
    "point2d": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "lineSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "start",
        "end"
      ],
      "properties": {
        "type": {
          "const": "LINE"
        },
        "start": {
          "$ref": "#/$defs/point2d"
        },
        "end": {
          "$ref": "#/$defs/point2d"
        }
      }
    },
    "arcSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "center",
        "radius",
        "start_angle",
        "end_angle"
      ],
      "properties": {
        "type": {
          "const": "ARC"
        },
        "center": {
          "$ref": "#/$defs/point2d"
        },
        "radius": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "start_angle": {
          "type": "number",
          "description": "Radians."
        },
        "end_angle": {
          "type": "number",
          "description": "Radians."
        }
      }
    },
    "ioDelay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "delay_seconds"
      ],
      "properties": {
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "delay_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "trigger_position",
        "state"
      ],
      "properties": {
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "trigger_position": {
          "type": "number",
          "minimum": 0,
          "description": "Cumulative path length in mm."
        },
        "state": {
          "type": "boolean"
        }
      }
    },
    "valve": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_delay_seconds",
        "close_delay_seconds"
      ],
      "properties": {
        "open_delay_seconds": {
          "type": "number",
          "minimum": 0
        },
        "close_delay_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  },
  "properties": {
    "timestep_seconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "max_simulation_time_seconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "max_velocity": {
      "type": "number",
      "minimum": 0
    },
    "max_acceleration": {
      "type": "number",
      "minimum": 0
    },
    "segments": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/lineSegment"
          },
          {
            "$ref": "#/$defs/arcSegment"
          }
        ]
      }
    },
    "io_delays": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ioDelay"
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trigger"
      }
    },
    "valve": {
      "$ref": "#/$defs/valve"
    }
  }
}
