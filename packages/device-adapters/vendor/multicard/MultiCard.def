LIBRARY MultiCard
EXPORTS
    ; 核心连接函数
    MC_Open
    MC_Close
    MC_Reset

    ; 轴控制函数
    MC_AxisOn
    MC_AxisOff

    ; 运动模式函数
    MC_PrfTrap
    MC_PrfJog
    MC_SetPos
    MC_SetVel
    MC_Update
    MC_Stop
    MC_EmergencyStop

    ; 参数设置函数
    MC_SetTrapPrm
    MC_SetJogPrm

    ; 状态查询函数
    MC_GetSts
    MC_GetPrfPos
    MC_GetAxisPrfPos
    MC_GetCrdPos
    MC_GetCrdVel
    MC_GetCrdStatus
    MC_GetAllSysStatusSX

    ; 坐标系函数
    MC_CrdStart
    MC_CrdStop
    MC_CrdClear
    MC_CrdData
    MC_CrdSpace
    MC_SetCrdPrm

    ; 插补函数
    MC_LnXY
    MC_ArcXYC
    MC_BufMoveEX

    ; 回零函数
    MC_HomeSetPrm
    MC_HomeStart
    MC_HomeStop

    ; IO控制函数
    MC_SetExtDoBit
    MC_GetDiRaw
    MC_GetExtDoValue
    MC_BufIO
    MC_BufWaitIO

    ; CMP触发函数
    MC_CmpPluse
    MC_CmpBufData
