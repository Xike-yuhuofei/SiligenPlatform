{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "group": "dxf",
  "operations": [
    {
      "method": "dxf.load",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["filepath"],
        "properties": {
          "filepath": { "type": "string" },
          "file_path": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["loaded", "artifact_id", "segment_count", "filepath"],
        "properties": {
          "loaded": { "type": "boolean" },
          "artifact_id": { "type": "string" },
          "segment_count": { "type": "integer" },
          "filepath": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2900, 2901, 2902, 2903],
      "consumers": [
        "hmi-client CommandProtocol.dxf_load",
        "Backend_CPP CLI DXF_PLAN",
        "Backend_CPP CLI DXF_DISPENSE"
      ],
      "compatibility": {
        "requestAliases": [
          {
            "canonical": "filepath",
            "accepted": ["filepath", "file_path"]
          }
        ],
        "notes": [
          "该命令是兼容入口；服务端会先创建 artifact，再由后续 plan/job 模型继续执行。"
        ]
      }
    },
    {
      "method": "dxf.artifact.create",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["filename", "file_content_b64"],
        "properties": {
          "filename": { "type": "string" },
          "original_filename": { "type": "string" },
          "content_type": { "type": "string" },
          "file_content_b64": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["created", "artifact_id", "filepath", "original_name", "generated_filename", "size", "timestamp"],
        "properties": {
          "created": { "type": "boolean" },
          "artifact_id": { "type": "string" },
          "filepath": { "type": "string" },
          "original_name": { "type": "string" },
          "generated_filename": { "type": "string" },
          "size": { "type": "integer" },
          "timestamp": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2890, 2891, 2892, 2893],
      "consumers": [
        "hmi-client CommandProtocol.dxf_create_artifact"
      ]
    },
    {
      "method": "dxf.plan.prepare",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["dispensing_speed_mm_s"],
        "properties": {
          "artifact_id": { "type": "string" },
          "dry_run": { "type": "boolean" },
          "dispensing_speed_mm_s": { "type": "number" },
          "speed_mm_s": { "type": "number" },
          "dry_run_speed_mm_s": { "type": "number" },
          "rapid_speed_mm_s": { "type": "number" },
          "optimize_path": { "type": "boolean" },
          "start_x": { "type": "number" },
          "start_y": { "type": "number" },
          "approximate_splines": { "type": "boolean" },
          "two_opt_iterations": { "type": "integer" },
          "spline_max_step_mm": { "type": "number" },
          "spline_max_error_mm": { "type": "number" },
          "arc_tolerance_mm": { "type": "number" },
          "arc_tolerance": { "type": "number" },
          "continuity_tolerance_mm": { "type": "number" },
          "continuity_tolerance": { "type": "number" },
          "curve_chain_angle_deg": { "type": "number" },
          "curve_chain_max_segment_mm": { "type": "number" },
          "max_jerk": { "type": "number" },
          "use_hardware_trigger": { "type": "boolean" },
          "use_interpolation_planner": { "type": "boolean" },
          "interpolation_algorithm": { "type": "integer" },
          "velocity_trace_enabled": { "type": "boolean" },
          "velocity_trace_interval_ms": { "type": "integer" },
          "velocity_trace_path": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["plan_id", "plan_fingerprint", "artifact_id", "segment_count", "point_count", "total_length_mm", "estimated_time_s", "generated_at"],
        "properties": {
          "plan_id": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "artifact_id": { "type": "string" },
          "segment_count": { "type": "integer" },
          "point_count": { "type": "integer" },
          "total_length_mm": { "type": "number" },
          "estimated_time_s": { "type": "number" },
          "generated_at": { "type": "string" },
          "snapshot_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "preview_request_signature": { "type": "string" },
          "preview_state": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2894, 2895, 2896, 2897],
      "consumers": [
        "hmi-client CommandProtocol.dxf_prepare_plan"
      ],
      "compatibility": {
        "requestAliases": [
          {
            "canonical": "dispensing_speed_mm_s",
            "accepted": ["dispensing_speed_mm_s", "speed_mm_s"]
          }
        ],
        "notes": [
          "artifact_id 允许省略；省略时服务端回退到最近一次已加载/已创建的 artifact。"
        ]
      }
    },
    {
      "method": "dxf.preview.snapshot",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["plan_id"],
        "properties": {
          "plan_id": { "type": "string" },
          "max_polyline_points": { "type": "integer", "minimum": 2 }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["snapshot_id", "snapshot_hash", "plan_id", "preview_state", "confirmed_at", "segment_count", "point_count", "polyline_point_count", "polyline_source_point_count", "trajectory_polyline", "total_length_mm", "estimated_time_s", "generated_at"],
        "properties": {
          "snapshot_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "plan_id": { "type": "string" },
          "preview_state": { "type": "string" },
          "confirmed_at": { "type": "string" },
          "segment_count": { "type": "integer" },
          "point_count": { "type": "integer" },
          "polyline_point_count": { "type": "integer" },
          "polyline_source_point_count": { "type": "integer" },
          "trajectory_polyline": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "total_length_mm": { "type": "number" },
          "estimated_time_s": { "type": "number" },
          "generated_at": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3010, 3011, 3012, 3013, 3014],
      "consumers": [
        "hmi-client CommandProtocol.dxf_preview_snapshot"
      ],
      "compatibility": {
        "notes": [
          "过渡期允许服务端在缺省 plan_id 时走兼容链路（prepare+snapshot），新客户端必须显式传 plan_id。"
        ]
      }
    },
    {
      "method": "dxf.preview.confirm",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["plan_id", "snapshot_hash"],
        "properties": {
          "plan_id": { "type": "string" },
          "snapshot_hash": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["confirmed", "plan_id", "snapshot_hash", "preview_state", "confirmed_at"],
        "properties": {
          "confirmed": { "type": "boolean" },
          "plan_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "preview_state": { "type": "string" },
          "confirmed_at": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3015, 3016, 3017, 3018],
      "consumers": [
        "hmi-client CommandProtocol.dxf_preview_confirm"
      ]
    },
    {
      "method": "dxf.job.start",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["plan_id", "plan_fingerprint"],
        "properties": {
          "plan_id": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "target_count": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["started", "job_id", "task_id", "plan_id", "plan_fingerprint", "target_count"],
        "properties": {
          "started": { "type": "boolean" },
          "job_id": { "type": "string" },
          "task_id": { "type": "string" },
          "plan_id": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "target_count": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2898, 2899, 2900, 2901],
      "consumers": [
        "hmi-client CommandProtocol.dxf_start_job"
      ],
      "compatibility": {
        "notes": [
          "过渡期服务端可回退最近一次 prepared plan；新客户端必须显式传入 plan_id 与 plan_fingerprint。"
        ]
      }
    },
    {
      "method": "dxf.execute",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["snapshot_hash"],
        "properties": {
          "dry_run": { "type": "boolean" },
          "dispensing_speed_mm_s": { "type": "number" },
          "dry_run_speed_mm_s": { "type": "number" },
          "rapid_speed_mm_s": { "type": "number" },
          "optimize_path": { "type": "boolean" },
          "start_x": { "type": "number" },
          "start_y": { "type": "number" },
          "approximate_splines": { "type": "boolean" },
          "two_opt_iterations": { "type": "integer" },
          "spline_max_step_mm": { "type": "number" },
          "spline_max_error_mm": { "type": "number" },
          "arc_tolerance_mm": { "type": "number" },
          "arc_tolerance": { "type": "number" },
          "continuity_tolerance_mm": { "type": "number" },
          "continuity_tolerance": { "type": "number" },
          "curve_chain_angle_deg": { "type": "number" },
          "curve_chain_max_segment_mm": { "type": "number" },
          "max_jerk": { "type": "number" },
          "use_hardware_trigger": { "type": "boolean" },
          "require_active_recipe": { "type": "boolean" },
          "use_interpolation_planner": { "type": "boolean" },
          "interpolation_algorithm": { "type": "integer" },
          "snapshot_hash": { "type": "string" },
          "target_count": { "type": "integer", "minimum": 1 },
          "velocity_trace_enabled": { "type": "boolean" },
          "velocity_trace_interval_ms": { "type": "integer" },
          "velocity_trace_path": { "type": "string" },
          "velocity_guard_enabled": { "type": "boolean" },
          "velocity_guard_ratio": { "type": "number" },
          "velocity_guard_abs_mm_s": { "type": "number" },
          "velocity_guard_min_expected_mm_s": { "type": "number" },
          "velocity_guard_grace_ms": { "type": "integer" },
          "velocity_guard_interval_ms": { "type": "integer" },
          "velocity_guard_max_consecutive": { "type": "integer" },
          "velocity_guard_stop_on_violation": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["executing", "task_id", "job_id", "plan_id", "snapshot_hash", "plan_fingerprint", "preview_request_signature", "target_count"],
        "properties": {
          "executing": { "type": "boolean" },
          "task_id": { "type": "string" },
          "job_id": { "type": "string" },
          "plan_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "preview_request_signature": { "type": "string" },
          "target_count": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3000, 3001, 3002, 3003, 3004, 3005, 3006, 3007, 3008],
      "consumers": [
        "hmi-client CommandProtocol.dxf_execute",
        "Backend_CPP CLI DXF_DISPENSE"
      ],
      "compatibility": {
        "rejectedLegacyParams": ["speed", "dry_run_speed", "dryRunSpeed"],
        "notes": [
          "HMI 当前只消费执行成功与否，不使用 task_id；TCP 仍返回 task_id 供后续查询。",
          "当 require_active_recipe=true 时，若无已激活配方则返回错误码 3004。",
          "该命令是兼容入口；服务端会把 snapshot_hash 门禁校验后映射为 job.start。"
        ]
      }
    },
    {
      "method": "dxf.job.pause",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["paused", "job_id"],
        "properties": {
          "paused": { "type": "boolean" },
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2905, 2906, 2907],
      "consumers": [
        "hmi-client CommandProtocol.dxf_job_pause"
      ]
    },
    {
      "method": "dxf.job.resume",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["resumed", "job_id"],
        "properties": {
          "resumed": { "type": "boolean" },
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2908, 2909, 2910],
      "consumers": [
        "hmi-client CommandProtocol.dxf_job_resume"
      ]
    },
    {
      "method": "dxf.job.stop",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["stopped", "job_id"],
        "properties": {
          "stopped": { "type": "boolean" },
          "job_id": { "type": "string" },
          "transition_state": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2911, 2912, 2913],
      "consumers": [
        "hmi-client CommandProtocol.dxf_job_stop"
      ]
    },
    {
      "method": "dxf.stop",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["stopped"],
        "properties": {
          "stopped": { "type": "boolean" },
          "transition_state": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3030, 3037],
      "consumers": [
        "hmi-client CommandProtocol.dxf_stop"
      ]
    },
    {
      "method": "dxf.pause",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["paused", "task_id"],
        "properties": {
          "paused": { "type": "boolean" },
          "task_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3031, 3032, 3033],
      "consumers": [
        "hmi-client CommandProtocol.dxf_pause"
      ]
    },
    {
      "method": "dxf.resume",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["resumed", "task_id"],
        "properties": {
          "resumed": { "type": "boolean" },
          "task_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3034, 3035, 3036],
      "consumers": [
        "hmi-client CommandProtocol.dxf_resume"
      ]
    }
  ]
}
