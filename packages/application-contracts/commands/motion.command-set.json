{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "group": "motion",
  "operations": [
    {
      "method": "home",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "axes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["X", "Y", "Z", "U"]
            }
          },
          "force": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["completed", "message"],
        "properties": {
          "completed": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2200, 2201, 2202],
      "consumers": [
        "hmi-client CommandProtocol.home",
        "Backend_CPP CLI HOME"
      ]
    },
    {
      "method": "home.go",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "axes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["X", "Y", "Z", "U"]
            }
          },
          "speed": { "type": "number" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["moving", "message"],
        "properties": {
          "moving": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2410, 2412, 2413, 2414, 2415, 2416],
      "consumers": [
        "hmi-client CommandProtocol.home_go"
      ]
    },
    {
      "method": "jog",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["axis", "direction"],
        "properties": {
          "axis": {
            "type": "string",
            "enum": ["X", "Y", "Z", "U"]
          },
          "direction": { "type": "integer" },
          "speed": { "type": "number" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["jogging"],
        "properties": {
          "jogging": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2300, 2301, 2302, 2303],
      "consumers": [
        "hmi-client CommandProtocol.jog",
        "Backend_CPP CLI JOG"
      ]
    },
    {
      "method": "move",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" },
          "speed": { "type": "number" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["moving"],
        "properties": {
          "moving": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2400, 2401, 2402],
      "consumers": [
        "hmi-client CommandProtocol.move_to",
        "Backend_CPP CLI MOVE"
      ]
    }
  ]
}
