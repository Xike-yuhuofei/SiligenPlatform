{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.process-runtime-core.redundancy/1.0",
  "group": "redundancy-governance",
  "version": "1.0.0",
  "operations": [
    {
      "method": "redundancy.entity.register",
      "kind": "command",
      "idempotent": true,
      "paramsSchema": {
        "type": "object",
        "required": [
          "entities"
        ],
        "properties": {
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "entity_id",
                "entity_type",
                "path",
                "module",
                "language"
              ],
              "properties": {
                "entity_id": {
                  "type": "string"
                },
                "entity_type": {
                  "type": "string",
                  "enum": [
                    "function",
                    "method",
                    "class",
                    "file",
                    "cmake_target"
                  ]
                },
                "path": {
                  "type": "string"
                },
                "symbol": {
                  "type": "string"
                },
                "signature": {
                  "type": "string"
                },
                "module": {
                  "type": "string"
                },
                "owner_target": {
                  "type": "string"
                },
                "language": {
                  "type": "string",
                  "enum": [
                    "cpp",
                    "header",
                    "cmake"
                  ]
                },
                "last_modified_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": [
          "received",
          "upserted"
        ],
        "properties": {
          "received": {
            "type": "integer",
            "minimum": 0
          },
          "upserted": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [
        7100,
        7199
      ]
    },
    {
      "method": "redundancy.evidence.static.report",
      "kind": "command",
      "idempotent": true,
      "paramsSchema": {
        "type": "object",
        "required": [
          "records"
        ],
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "evidence_id",
                "entity_id",
                "rule_id",
                "rule_version",
                "signal_type",
                "signal_strength",
                "details",
                "collected_at"
              ],
              "properties": {
                "evidence_id": {
                  "type": "string"
                },
                "entity_id": {
                  "type": "string"
                },
                "rule_id": {
                  "type": "string"
                },
                "rule_version": {
                  "type": "string"
                },
                "signal_type": {
                  "type": "string",
                  "enum": [
                    "unreferenced",
                    "unreachable",
                    "duplicate",
                    "isolated"
                  ]
                },
                "signal_strength": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "details": {
                  "type": "object"
                },
                "collected_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": [
          "received",
          "accepted",
          "rejected"
        ],
        "properties": {
          "received": {
            "type": "integer",
            "minimum": 0
          },
          "accepted": {
            "type": "integer",
            "minimum": 0
          },
          "rejected": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [
        7100,
        7101,
        7199
      ]
    },
    {
      "method": "redundancy.evidence.runtime.report",
      "kind": "command",
      "idempotent": true,
      "paramsSchema": {
        "type": "object",
        "required": [
          "records"
        ],
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "evidence_id",
                "entity_id",
                "environment",
                "window_start",
                "window_end",
                "hit_count",
                "source",
                "collected_at"
              ],
              "properties": {
                "evidence_id": {
                  "type": "string"
                },
                "entity_id": {
                  "type": "string"
                },
                "environment": {
                  "type": "string",
                  "enum": [
                    "test",
                    "staging",
                    "canary"
                  ]
                },
                "window_start": {
                  "type": "string",
                  "format": "date-time"
                },
                "window_end": {
                  "type": "string",
                  "format": "date-time"
                },
                "hit_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "last_hit_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "source": {
                  "type": "string"
                },
                "collected_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": [
          "received",
          "accepted",
          "rejected"
        ],
        "properties": {
          "received": {
            "type": "integer",
            "minimum": 0
          },
          "accepted": {
            "type": "integer",
            "minimum": 0
          },
          "rejected": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [
        7100,
        7101,
        7199
      ]
    },
    {
      "method": "redundancy.candidate.compute",
      "kind": "command",
      "idempotent": false,
      "paramsSchema": {
        "type": "object",
        "required": [
          "module",
          "window_start",
          "window_end",
          "policy_version"
        ],
        "properties": {
          "module": {
            "type": "string"
          },
          "window_start": {
            "type": "string",
            "format": "date-time"
          },
          "window_end": {
            "type": "string",
            "format": "date-time"
          },
          "policy_version": {
            "type": "string"
          },
          "force_recompute": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": [
          "snapshot_id",
          "generated_candidates"
        ],
        "properties": {
          "snapshot_id": {
            "type": "string"
          },
          "generated_candidates": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [
        7100,
        7199
      ]
    },
    {
      "method": "redundancy.candidate.list",
      "kind": "query",
      "idempotent": true,
      "paramsSchema": {
        "type": "object",
        "properties": {
          "module": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "NEW",
              "REVIEWED",
              "DEPRECATED",
              "OBSERVED",
              "REMOVED",
              "ROLLED_BACK"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "min_redundancy_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "max_deletion_risk_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000,
            "default": 200
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": [
          "total",
          "items"
        ],
        "properties": {
          "total": {
            "type": "integer",
            "minimum": 0
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "candidate_id",
                "entity_id",
                "redundancy_score",
                "deletion_risk_score",
                "priority",
                "recommended_action",
                "status",
                "computed_at"
              ],
              "properties": {
                "candidate_id": {
                  "type": "string"
                },
                "entity_id": {
                  "type": "string"
                },
                "redundancy_score": {
                  "type": "number"
                },
                "deletion_risk_score": {
                  "type": "number"
                },
                "priority": {
                  "type": "string"
                },
                "recommended_action": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "computed_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [
        7100,
        7199
      ]
    },
    {
      "method": "redundancy.workflow.transition",
      "kind": "command",
      "idempotent": false,
      "paramsSchema": {
        "type": "object",
        "required": [
          "candidate_id",
          "from_status",
          "to_status",
          "actor",
          "reason"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "from_status": {
            "type": "string",
            "enum": [
              "NEW",
              "REVIEWED",
              "DEPRECATED",
              "OBSERVED",
              "REMOVED",
              "ROLLED_BACK"
            ]
          },
          "to_status": {
            "type": "string",
            "enum": [
              "NEW",
              "REVIEWED",
              "DEPRECATED",
              "OBSERVED",
              "REMOVED",
              "ROLLED_BACK"
            ]
          },
          "actor": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "ticket": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": [
          "candidate_id",
          "status",
          "transitioned_at"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "transitioned_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [
        7100,
        7101,
        7102,
        7199
      ]
    },
    {
      "method": "redundancy.decision.log.append",
      "kind": "command",
      "idempotent": true,
      "paramsSchema": {
        "type": "object",
        "required": [
          "decision_id",
          "candidate_id",
          "action",
          "actor",
          "reason",
          "evidence_snapshot",
          "created_at"
        ],
        "properties": {
          "decision_id": {
            "type": "string"
          },
          "candidate_id": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "approve",
              "reject",
              "deprecate",
              "remove",
              "rollback"
            ]
          },
          "actor": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "evidence_snapshot": {
            "type": "object"
          },
          "ticket": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": [
          "appended"
        ],
        "properties": {
          "appended": {
            "type": "boolean",
            "const": true
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [
        7100,
        7101,
        7104,
        7199
      ]
    }
  ],
  "errors": [
    {
      "code": 7100,
      "name": "invalid_payload",
      "message": "请求体不满足契约定义。"
    },
    {
      "code": 7101,
      "name": "entity_or_candidate_not_found",
      "message": "实体或候选不存在。"
    },
    {
      "code": 7102,
      "name": "invalid_state_transition",
      "message": "状态迁移不符合状态机规则。"
    },
    {
      "code": 7104,
      "name": "duplicate_decision_id",
      "message": "决策日志 ID 重复。"
    },
    {
      "code": 7199,
      "name": "internal_error",
      "message": "内部错误。"
    }
  ]
}
