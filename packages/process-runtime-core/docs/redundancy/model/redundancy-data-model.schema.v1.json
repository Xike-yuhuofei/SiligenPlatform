{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "model": "siligen.process-runtime-core.redundancy/1.0",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "codeEntities",
    "staticEvidence",
    "runtimeEvidence",
    "candidates",
    "decisionLogs"
  ],
  "properties": {
    "codeEntities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/codeEntity"
      }
    },
    "staticEvidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/staticEvidence"
      }
    },
    "runtimeEvidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runtimeEvidence"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "decisionLogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionLog"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "datetime": {
      "type": "string",
      "format": "date-time"
    },
    "jsonObject": {
      "type": "object"
    },
    "codeEntity": {
      "type": "object",
      "required": [
        "entity_id",
        "entity_type",
        "path",
        "module",
        "language"
      ],
      "properties": {
        "entity_id": {
          "$ref": "#/$defs/id"
        },
        "entity_type": {
          "type": "string",
          "enum": [
            "function",
            "method",
            "class",
            "file",
            "cmake_target"
          ]
        },
        "symbol": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string"
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "owner_target": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": [
            "cpp",
            "header",
            "cmake"
          ]
        },
        "last_modified_at": {
          "$ref": "#/$defs/datetime"
        }
      },
      "additionalProperties": false
    },
    "staticEvidence": {
      "type": "object",
      "required": [
        "evidence_id",
        "entity_id",
        "rule_id",
        "rule_version",
        "signal_type",
        "signal_strength",
        "details",
        "collected_at"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/id"
        },
        "entity_id": {
          "$ref": "#/$defs/id"
        },
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "rule_version": {
          "type": "string",
          "minLength": 1
        },
        "signal_type": {
          "type": "string",
          "enum": [
            "unreferenced",
            "unreachable",
            "duplicate",
            "isolated"
          ]
        },
        "signal_strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "details": {
          "$ref": "#/$defs/jsonObject"
        },
        "collected_at": {
          "$ref": "#/$defs/datetime"
        }
      },
      "additionalProperties": false
    },
    "runtimeEvidence": {
      "type": "object",
      "required": [
        "evidence_id",
        "entity_id",
        "environment",
        "window_start",
        "window_end",
        "hit_count",
        "source",
        "collected_at"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/id"
        },
        "entity_id": {
          "$ref": "#/$defs/id"
        },
        "environment": {
          "type": "string",
          "enum": [
            "test",
            "staging",
            "canary"
          ]
        },
        "window_start": {
          "$ref": "#/$defs/datetime"
        },
        "window_end": {
          "$ref": "#/$defs/datetime"
        },
        "hit_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_hit_at": {
          "$ref": "#/$defs/datetime"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "collected_at": {
          "$ref": "#/$defs/datetime"
        }
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "entity_id",
        "redundancy_score",
        "deletion_risk_score",
        "priority",
        "recommended_action",
        "status",
        "computed_at"
      ],
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/id"
        },
        "entity_id": {
          "$ref": "#/$defs/id"
        },
        "redundancy_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "deletion_risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "recommended_action": {
          "type": "string",
          "enum": [
            "observe",
            "deprecate",
            "remove",
            "hold"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "NEW",
            "REVIEWED",
            "DEPRECATED",
            "OBSERVED",
            "REMOVED",
            "ROLLED_BACK"
          ]
        },
        "computed_at": {
          "$ref": "#/$defs/datetime"
        }
      },
      "additionalProperties": false
    },
    "decisionLog": {
      "type": "object",
      "required": [
        "decision_id",
        "candidate_id",
        "action",
        "actor",
        "reason",
        "evidence_snapshot",
        "created_at"
      ],
      "properties": {
        "decision_id": {
          "$ref": "#/$defs/id"
        },
        "candidate_id": {
          "$ref": "#/$defs/id"
        },
        "action": {
          "type": "string",
          "enum": [
            "approve",
            "reject",
            "deprecate",
            "remove",
            "rollback"
          ]
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence_snapshot": {
          "$ref": "#/$defs/jsonObject"
        },
        "ticket": {
          "type": "string"
        },
        "created_at": {
          "$ref": "#/$defs/datetime"
        }
      },
      "additionalProperties": false
    }
  },
  "storageHints": {
    "primaryKeys": {
      "codeEntities": [
        "entity_id"
      ],
      "staticEvidence": [
        "evidence_id"
      ],
      "runtimeEvidence": [
        "evidence_id"
      ],
      "candidates": [
        "candidate_id"
      ],
      "decisionLogs": [
        "decision_id"
      ]
    },
    "foreignKeys": [
      {
        "from": "staticEvidence.entity_id",
        "to": "codeEntities.entity_id"
      },
      {
        "from": "runtimeEvidence.entity_id",
        "to": "codeEntities.entity_id"
      },
      {
        "from": "candidates.entity_id",
        "to": "codeEntities.entity_id"
      },
      {
        "from": "decisionLogs.candidate_id",
        "to": "candidates.candidate_id"
      }
    ],
    "recommendedIndexes": [
      [
        "codeEntities.module",
        "codeEntities.entity_type"
      ],
      [
        "codeEntities.path"
      ],
      [
        "staticEvidence.entity_id",
        "staticEvidence.signal_type"
      ],
      [
        "runtimeEvidence.entity_id",
        "runtimeEvidence.window_end"
      ],
      [
        "candidates.status",
        "candidates.priority"
      ],
      [
        "candidates.entity_id"
      ],
      [
        "decisionLogs.candidate_id",
        "decisionLogs.created_at"
      ]
    ]
  }
}
