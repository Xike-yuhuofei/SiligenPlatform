{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "group": "core",
  "operations": [
    {
      "method": "connect",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "card_ip": { "type": "string" },
          "local_ip": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["connected", "message"],
        "properties": {
          "connected": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2000, 2001],
      "consumers": [
        "hmi-client CommandProtocol.connect_hardware",
        "Backend_CPP CLI CONNECT"
      ],
      "compatibility": {
        "notes": [
          "TCP 处理器当前固定 auto_connect_hardware=true。"
        ]
      }
    },
    {
      "method": "disconnect",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["disconnected"],
        "properties": {
          "disconnected": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "errorCodes": [],
      "consumers": [
        "Backend_CPP CLI DISCONNECT"
      ],
      "compatibility": {
        "notes": [
          "TCP 处理器返回幂等断开确认；物理链路回收由客户端或宿主进程自行处理。"
        ]
      }
    },
    {
      "method": "stop",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["stopped"],
        "properties": {
          "stopped": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2500],
      "consumers": [
        "hmi-client CommandProtocol.stop",
        "Backend_CPP CLI STOP_ALL"
      ]
    },
    {
      "method": "estop",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["motion_stopped", "message"],
        "properties": {
          "motion_stopped": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2600, 2601],
      "consumers": [
        "hmi-client CommandProtocol.emergency_stop",
        "Backend_CPP CLI EMERGENCY_STOP"
      ]
    },
    {
      "method": "estop.reset",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["reset", "message"],
        "properties": {
          "reset": { "type": "boolean", "const": true },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2602, 2603],
      "consumers": [
        "hmi-client CommandProtocol.estop_reset"
      ]
    },
    {
      "method": "mock.io.set",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "estop": { "type": "boolean" },
          "door": { "type": "boolean" },
          "limit_x_neg": { "type": "boolean" },
          "limit_y_neg": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["estop", "door", "limit_x_neg", "limit_y_neg"],
        "properties": {
          "estop": { "type": "boolean" },
          "door": { "type": "boolean" },
          "limit_x_neg": { "type": "boolean" },
          "limit_y_neg": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2050, 2051, 2052],
      "consumers": [
        "hmi-client CommandProtocol.mock_io_set",
        "tests/e2e first-layer tcp door/limit probes"
      ],
      "compatibility": {
        "notes": [
          "仅在 Hardware.mode=Mock 下可用。",
          "door 依赖 [Interlock].safety_door_input 为有效输入位；若配置为 -1 将稳定报错。"
        ]
      }
    }
  ]
}
