          "preview_failure_reason": { "type": "string" },
          "preview_diagnostic_code": { "type": "string" },
          "confirmed_at": { "type": "string" },
          "segment_count": { "type": "integer" },
          "point_count": { "type": "integer" },
          "glue_point_count": { "type": "integer" },
          "glue_points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "glue_reveal_lengths_mm": {
            "type": "array",
            "items": { "type": "number" }
          },
          "preview_binding": {
            "type": "object",
            "required": ["source", "status", "layout_id", "glue_point_count", "binding_basis", "display_path_length_mm", "source_trigger_indices", "display_reveal_lengths_mm", "diagnostic_code", "failure_reason"],
            "properties": {
              "source": { "type": "string" },
              "status": { "type": "string" },
              "layout_id": { "type": "string" },
              "glue_point_count": { "type": "integer" },
              "binding_basis": { "type": "string" },
              "display_path_length_mm": { "type": "number" },
              "source_trigger_indices": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 }
              },
              "display_reveal_lengths_mm": {
                "type": "array",
                "items": { "type": "number" }
              },
              "diagnostic_code": { "type": "string" },
              "failure_reason": { "type": "string" }
            },
            "additionalProperties": false
          },
          "execution_point_count": { "type": "integer" },
          "motion_preview": {
            "type": "object",
            "required": ["source", "kind", "source_point_count", "point_count", "is_sampled", "sampling_strategy", "polyline"],
            "properties": {
              "source": { "type": "string" },
              "kind": { "type": "string" },
              "source_point_count": { "type": "integer" },
              "point_count": { "type": "integer" },
              "is_sampled": { "type": "boolean" },
              "sampling_strategy": { "type": "string" },
              "polyline": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["x", "y"],
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "total_length_mm": { "type": "number" },
          "estimated_time_s": { "type": "number" },
          "path_quality": {
            "type": "object",
            "required": ["verdict", "blocking", "reason_codes"],
            "properties": {
              "verdict": { "type": "string", "enum": ["pass", "pass_with_exception", "fail"] },
              "blocking": { "type": "boolean" },
              "reason_codes": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "generated_at": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3010, 3011, 3012, 3013, 3014],
      "consumers": [
        "hmi-client CommandProtocol.dxf_preview_snapshot"
      ],
      "compatibility": {
        "notes": [
          "live chain 仅接受显式 plan_id；dxf.preview.snapshot 缺少 plan_id 时必须直接失败，不得在 snapshot 内部隐式 prepare。",
          "成功响应仅适用于 shared authority 预览：preview、confirm、start-job 必须共享同一 authority layout、layout_id 与 binding gate 结果。",
          "成功形态固定为 preview_source=planned_glue_snapshot + preview_kind=glue_points + 非空 glue_points + preview_binding.status=ready；authority 缺失、binding 缺失或 preview/execution 不共享 layout 时必须返回失败，而不是伪装成可显示 preview。"
        ]
      }
    },
