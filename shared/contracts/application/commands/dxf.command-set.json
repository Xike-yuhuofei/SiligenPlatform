        "required": ["plan_id", "plan_fingerprint", "artifact_id", "segment_count", "point_count", "total_length_mm", "execution_nominal_time_s", "execution_plan_summary", "generated_at", "production_baseline", "prepared_filepath", "import_result_classification", "import_preview_ready", "import_production_ready", "formal_compare_gate", "import_summary", "import_primary_code", "import_warning_codes", "import_error_codes", "import_resolved_units", "import_resolved_unit_scale", "path_quality"],
        "properties": {
          "plan_id": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "artifact_id": { "type": "string" },
          "prepared_filepath": { "type": "string" },
          "segment_count": { "type": "integer" },
          "point_count": { "type": "integer" },
