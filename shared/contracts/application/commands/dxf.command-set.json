            "properties": {
              "geometry_kind": { "type": "string" },
              "execution_strategy": { "type": "string" },
              "production_trigger_mode": { "type": "string" },
              "interpolation_segment_count": { "type": "integer" },
              "interpolation_point_count": { "type": "integer" },
              "motion_point_count": { "type": "integer" },
              "trigger_count": { "type": "integer" },
              "owner_span_count": { "type": "integer" },
              "immediate_only_span_count": { "type": "integer" },
              "future_compare_span_count": { "type": "integer" }
            },
            "additionalProperties": false
          },
          "production_baseline": {
            "type": "object",
            "required": ["baseline_id", "baseline_fingerprint"],
            "properties": {
              "baseline_id": { "type": "string" },
              "baseline_fingerprint": { "type": "string" }
            },
            "additionalProperties": false
          },
          "import_result_classification": { "type": "string" },
          "import_preview_ready": { "type": "boolean" },
          "import_production_ready": { "type": "boolean" },
          "formal_compare_gate": {
            "type": ["object", "null"],
            "required": ["status", "reason_code", "authority_span_ref", "trigger_begin_index", "current_start_position_mm", "next_trigger_position_mm", "candidate_failures"],
            "properties": {
              "status": { "type": "string" },
              "reason_code": { "type": "string" },
              "authority_span_ref": { "type": "string" },
              "trigger_begin_index": { "type": "integer" },
              "current_start_position_mm": {
                "type": "object",
                "required": ["x", "y"],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                },
                "additionalProperties": false
              },
              "next_trigger_position_mm": {
                "type": "object",
                "required": ["x", "y"],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                },
                "additionalProperties": false
              },
              "candidate_failures": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "import_summary": { "type": "string" },
          "import_primary_code": { "type": "string" },
          "import_warning_codes": { "type": "array", "items": { "type": "string" } },
          "import_error_codes": { "type": "array", "items": { "type": "string" } },
          "import_resolved_units": { "type": "string" },
          "import_resolved_unit_scale": { "type": "number" },
          "generated_at": { "type": "string" },
          "snapshot_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "preview_validation_classification": { "type": "string" },
          "preview_exception_reason": { "type": "string" },
          "preview_failure_reason": { "type": "string" },
          "preview_diagnostic_code": { "type": "string" },
          "path_quality": {
            "type": "object",
            "required": ["verdict", "blocking", "reason_codes"],
            "properties": {
              "verdict": { "type": "string", "enum": ["pass", "pass_with_exception", "fail"] },
              "blocking": { "type": "boolean" },
              "reason_codes": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "preview_request_signature": { "type": "string" },
          "preview_state": { "type": "string" },
          "performance_profile": {
            "type": "object",
            "properties": {
              "authority_cache_hit": { "type": "boolean" },
              "authority_joined_inflight": { "type": "boolean" },
              "authority_wait_ms": { "type": "integer" },
              "pb_prepare_ms": { "type": "integer" },
              "path_load_ms": { "type": "integer" },
              "process_path_ms": { "type": "integer" },
              "authority_build_ms": { "type": "integer" },
              "authority_total_ms": { "type": "integer" },
              "prepare_total_ms": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [2894, 2895, 2896, 2897],
      "consumers": [
        "hmi-client CommandProtocol.dxf_prepare_plan"
      ],
      "compatibility": {
        "notes": [
          "artifact_id 必须显式提供；服务端不再回退最近 artifact 或其他全局活动态。",
          "当前阶段 prepare 链路基于 current production baseline 解析 point_flying_carrier_policy，不再依赖任何 recipe/version 全局态。requested_execution_strategy 为可选显式执行策略；未传时默认按 flying_shot 解析。POINT 若无 formal carrier trajectory，仅允许基于 baseline-owned point_flying_carrier_policy，并按 approach_direction = normalize(point - planning_start_position) 合成 formal carrier trajectory。"
        ]
      }
    },
    {
      "method": "dxf.preview.snapshot",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["plan_id"],
        "properties": {
          "plan_id": { "type": "string" },
          "max_polyline_points": { "type": "integer", "minimum": 2 },
          "max_glue_points": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["snapshot_id", "snapshot_hash", "plan_id", "preview_state", "preview_source", "preview_kind", "confirmed_at", "segment_count", "point_count", "glue_point_count", "glue_points", "glue_reveal_lengths_mm", "preview_binding", "motion_preview", "execution_point_count", "total_length_mm", "estimated_time_s", "generated_at", "path_quality"],
        "properties": {
          "snapshot_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "plan_id": { "type": "string" },
