{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "group": "dxf",
  "operations": [
    {
      "method": "dxf.load",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["filepath"],
        "properties": {
          "filepath": { "type": "string" },
          "file_path": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["loaded", "artifact_id", "segment_count", "filepath"],
        "properties": {
          "loaded": { "type": "boolean" },
          "artifact_id": { "type": "string" },
          "segment_count": { "type": "integer" },
          "filepath": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2900, 2901, 2902, 2903],
      "consumers": [
        "hmi-client CommandProtocol.dxf_load",
        "Backend_CPP CLI DXF_PLAN",
        "Backend_CPP CLI DXF_DISPENSE"
      ],
      "compatibility": {
        "requestAliases": [
          {
            "canonical": "filepath",
            "accepted": ["filepath", "file_path"]
          }
        ],
        "notes": [
          "该命令是兼容入口；服务端会先创建 artifact，再由后续 plan/job 模型继续执行。"
        ]
      }
    },
    {
      "method": "dxf.artifact.create",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["filename", "file_content_b64"],
        "properties": {
          "filename": { "type": "string" },
          "original_filename": { "type": "string" },
          "content_type": { "type": "string" },
          "file_content_b64": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["created", "artifact_id", "filepath", "original_name", "generated_filename", "size", "timestamp"],
        "properties": {
          "created": { "type": "boolean" },
          "artifact_id": { "type": "string" },
          "filepath": { "type": "string" },
          "original_name": { "type": "string" },
          "generated_filename": { "type": "string" },
          "size": { "type": "integer" },
          "timestamp": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2890, 2891, 2892, 2893],
      "consumers": [
        "hmi-client CommandProtocol.dxf_create_artifact"
      ]
    },
    {
      "method": "dxf.plan.prepare",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["dispensing_speed_mm_s"],
        "properties": {
          "artifact_id": { "type": "string" },
          "dry_run": { "type": "boolean" },
          "dispensing_speed_mm_s": { "type": "number" },
          "speed_mm_s": { "type": "number" },
          "dry_run_speed_mm_s": { "type": "number" },
          "rapid_speed_mm_s": { "type": "number" },
          "optimize_path": { "type": "boolean" },
          "start_x": { "type": "number" },
          "start_y": { "type": "number" },
          "approximate_splines": { "type": "boolean" },
          "two_opt_iterations": { "type": "integer" },
          "spline_max_step_mm": { "type": "number" },
          "spline_max_error_mm": { "type": "number" },
          "arc_tolerance_mm": { "type": "number" },
          "arc_tolerance": { "type": "number" },
          "continuity_tolerance_mm": { "type": "number" },
          "continuity_tolerance": { "type": "number" },
          "curve_chain_angle_deg": { "type": "number" },
          "curve_chain_max_segment_mm": { "type": "number" },
          "max_jerk": { "type": "number" },
          "use_hardware_trigger": { "type": "boolean" },
          "use_interpolation_planner": { "type": "boolean" },
          "interpolation_algorithm": { "type": "integer" },
          "velocity_trace_enabled": { "type": "boolean" },
          "velocity_trace_interval_ms": { "type": "integer" },
          "velocity_trace_path": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["plan_id", "plan_fingerprint", "artifact_id", "segment_count", "point_count", "total_length_mm", "estimated_time_s", "generated_at"],
        "properties": {
          "plan_id": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "artifact_id": { "type": "string" },
          "segment_count": { "type": "integer" },
          "point_count": { "type": "integer" },
          "total_length_mm": { "type": "number" },
          "estimated_time_s": { "type": "number" },
          "generated_at": { "type": "string" },
          "snapshot_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "preview_validation_classification": { "type": "string" },
          "preview_exception_reason": { "type": "string" },
          "preview_failure_reason": { "type": "string" },
          "preview_diagnostic_code": { "type": "string" },
          "preview_request_signature": { "type": "string" },
          "preview_state": { "type": "string" },
          "performance_profile": {
            "type": "object",
            "properties": {
              "authority_cache_hit": { "type": "boolean" },
              "authority_joined_inflight": { "type": "boolean" },
              "authority_wait_ms": { "type": "integer" },
              "pb_prepare_ms": { "type": "integer" },
              "path_load_ms": { "type": "integer" },
              "process_path_ms": { "type": "integer" },
              "authority_build_ms": { "type": "integer" },
              "authority_total_ms": { "type": "integer" },
              "prepare_total_ms": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [2894, 2895, 2896, 2897],
      "consumers": [
        "hmi-client CommandProtocol.dxf_prepare_plan"
      ],
      "compatibility": {
        "requestAliases": [
          {
            "canonical": "dispensing_speed_mm_s",
            "accepted": ["dispensing_speed_mm_s", "speed_mm_s"]
          }
        ],
        "notes": [
          "artifact_id 允许省略；省略时服务端回退到最近一次已加载/已创建的 artifact。"
        ]
      }
    },
    {
      "method": "dxf.preview.snapshot",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["plan_id"],
        "properties": {
          "plan_id": { "type": "string" },
          "max_polyline_points": { "type": "integer", "minimum": 2 },
          "max_glue_points": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["snapshot_id", "snapshot_hash", "plan_id", "preview_state", "preview_source", "preview_kind", "confirmed_at", "segment_count", "point_count", "glue_point_count", "glue_points", "glue_reveal_lengths_mm", "motion_preview", "execution_point_count", "total_length_mm", "estimated_time_s", "generated_at"],
        "properties": {
          "snapshot_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "plan_id": { "type": "string" },
          "preview_state": { "type": "string" },
          "preview_source": { "type": "string" },
          "preview_kind": { "type": "string" },
          "preview_validation_classification": { "type": "string" },
          "preview_exception_reason": { "type": "string" },
          "preview_failure_reason": { "type": "string" },
          "preview_diagnostic_code": { "type": "string" },
          "confirmed_at": { "type": "string" },
          "segment_count": { "type": "integer" },
          "point_count": { "type": "integer" },
          "glue_point_count": { "type": "integer" },
          "glue_points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "glue_reveal_lengths_mm": {
            "type": "array",
            "items": { "type": "number" }
          },
          "execution_point_count": { "type": "integer" },
          "motion_preview": {
            "type": "object",
            "required": ["source", "kind", "source_point_count", "point_count", "is_sampled", "sampling_strategy", "polyline"],
            "properties": {
              "source": { "type": "string" },
              "kind": { "type": "string" },
              "source_point_count": { "type": "integer" },
              "point_count": { "type": "integer" },
              "is_sampled": { "type": "boolean" },
              "sampling_strategy": { "type": "string" },
              "polyline": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["x", "y"],
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "total_length_mm": { "type": "number" },
          "estimated_time_s": { "type": "number" },
          "generated_at": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3010, 3011, 3012, 3013, 3014],
      "consumers": [
        "hmi-client CommandProtocol.dxf_preview_snapshot"
      ],
      "compatibility": {
        "notes": [
          "live chain 仅接受显式 plan_id；dxf.preview.snapshot 缺少 plan_id 时必须直接失败，不得在 snapshot 内部隐式 prepare。",
          "成功响应仅适用于 shared authority 预览：preview、confirm、start-job 必须共享同一 authority layout、layout_id 与 binding gate 结果。",
          "成功形态固定为 preview_source=planned_glue_snapshot + preview_kind=glue_points + 非空 glue_points；authority 缺失、binding 缺失或 preview/execution 不共享 layout 时必须返回失败，而不是伪装成可显示 preview。"
        ]
      }
    },
    {
      "method": "dxf.preview.confirm",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["plan_id", "snapshot_hash"],
        "properties": {
          "plan_id": { "type": "string" },
          "snapshot_hash": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["confirmed", "plan_id", "snapshot_hash", "preview_state", "confirmed_at"],
        "properties": {
          "confirmed": { "type": "boolean" },
          "plan_id": { "type": "string" },
          "snapshot_hash": { "type": "string" },
          "preview_state": { "type": "string" },
          "confirmed_at": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [3015, 3016, 3017, 3018],
      "consumers": [
        "hmi-client CommandProtocol.dxf_preview_confirm"
      ]
    },
    {
      "method": "dxf.job.start",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["plan_id", "plan_fingerprint"],
        "properties": {
          "plan_id": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "target_count": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["started", "job_id", "plan_id", "plan_fingerprint", "target_count", "performance_profile"],
        "properties": {
          "started": { "type": "boolean" },
          "job_id": { "type": "string" },
          "plan_id": { "type": "string" },
          "plan_fingerprint": { "type": "string" },
          "target_count": { "type": "integer" },
          "performance_profile": {
            "type": "object",
            "properties": {
              "execution_cache_hit": { "type": "boolean" },
              "execution_joined_inflight": { "type": "boolean" },
              "execution_wait_ms": { "type": "integer" },
              "motion_plan_ms": { "type": "integer" },
              "assembly_ms": { "type": "integer" },
              "export_ms": { "type": "integer" },
              "execution_total_ms": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "errorCodes": [2898, 2899, 2900, 2901],
      "consumers": [
        "hmi-client CommandProtocol.dxf_start_job"
      ],
      "compatibility": {
        "notes": [
          "过渡期服务端可回退最近一次 prepared plan；新客户端必须显式传入 plan_id 与 plan_fingerprint。"
        ]
      }
    },
    {
      "method": "dxf.job.pause",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["paused", "job_id"],
        "properties": {
          "paused": { "type": "boolean" },
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2905, 2906, 2907],
      "consumers": [
        "hmi-client CommandProtocol.dxf_job_pause"
      ]
    },
    {
      "method": "dxf.job.resume",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["resumed", "job_id"],
        "properties": {
          "resumed": { "type": "boolean" },
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2908, 2909, 2910],
      "consumers": [
        "hmi-client CommandProtocol.dxf_job_resume"
      ]
    },
    {
      "method": "dxf.job.stop",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["stopped", "job_id", "transition_state", "message"],
        "properties": {
          "stopped": { "type": "boolean" },
          "job_id": { "type": "string" },
          "transition_state": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2911, 2912, 2913],
      "consumers": [
        "hmi-client CommandProtocol.dxf_job_stop"
      ]
    },
    {
      "method": "dxf.job.cancel",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["cancelled", "job_id", "transition_state", "message"],
        "properties": {
          "cancelled": { "type": "boolean" },
          "job_id": { "type": "string" },
          "transition_state": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2914, 2915, 2916],
      "consumers": [
        "hmi-client CommandProtocol.dxf_job_cancel"
      ]
    }
  ]
}
