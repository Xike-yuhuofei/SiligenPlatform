{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "group": "motion",
  "operations": [
    {
      "method": "home",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "axes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["X", "Y", "Z", "U"]
            }
          },
          "force": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["completed", "message"],
        "properties": {
          "completed": { "type": "boolean" },
          "message": { "type": "string" },
          "succeeded_axes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["X", "Y", "Z", "U"]
            }
          },
          "failed_axes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["X", "Y", "Z", "U"]
            }
          },
          "error_messages": {
            "type": "array",
            "items": { "type": "string" }
          },
          "total_time_ms": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2200, 2201, 2202],
      "consumers": [
        "hmi-client CommandProtocol.home",
        "Backend_CPP CLI HOME"
      ]
    },
    {
      "method": "home.go",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "axes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["X", "Y", "Z", "U"]
            }
          },
          "speed": { "type": "number" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["moving", "message"],
        "properties": {
          "moving": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2410, 2411, 2412, 2413, 2414, 2415, 2416, 2417],
      "consumers": [
        "hmi-client CommandProtocol.home_go"
      ],
      "compatibility": {
        "notes": [
          "调用前目标轴必须已完成回零；急停或门互锁锁存时 TCP 入口直接拒绝执行。"
        ]
      }
    },
    {
      "method": "home.auto",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "properties": {
          "axes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["X", "Y", "Z", "U"]
            }
          },
          "force": { "type": "boolean" },
          "wait_for_completion": { "type": "boolean" },
          "timeout_ms": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["accepted", "summary_state", "message", "axis_results", "total_time_ms"],
        "properties": {
          "accepted": { "type": "boolean" },
          "summary_state": { "type": "string" },
          "message": { "type": "string" },
          "axis_results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "axis",
                "supervisor_state",
                "planned_action",
                "executed",
                "success",
                "reason_code",
                "message"
              ],
              "properties": {
                "axis": {
                  "type": "string",
                  "enum": ["X", "Y", "Z", "U"]
                },
                "supervisor_state": {
                  "type": "string",
                  "enum": [
                    "blocked",
                    "homing_in_progress",
                    "not_homed",
                    "homed_at_zero",
                    "homed_away_from_zero"
                  ]
                },
                "planned_action": {
                  "type": "string",
                  "enum": ["reject", "noop", "home", "go_home"]
                },
                "executed": { "type": "boolean" },
                "success": { "type": "boolean" },
                "reason_code": { "type": "string" },
                "message": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "total_time_ms": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2420, 2421, 2422, 2423, 2424],
      "consumers": [
        "hmi-client CommandProtocol.home_auto"
      ],
      "compatibility": {
        "notes": [
          "单按钮高层回零命令；以监督态决定是执行 home、go_home 还是直接 noop，HMI 不再自行切换 home/home.go。"
        ]
      }
    },
    {
      "method": "jog",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["axis", "direction"],
        "properties": {
          "axis": {
            "type": "string",
            "enum": ["X", "Y", "Z", "U"]
          },
          "direction": { "type": "integer" },
          "speed": { "type": "number" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["jogging"],
        "properties": {
          "jogging": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2300, 2301, 2302, 2303, 2304, 2305],
      "consumers": [
        "hmi-client CommandProtocol.jog",
        "Backend_CPP CLI JOG"
      ],
      "compatibility": {
        "notes": [
          "点动前要求轴已回零；急停或门互锁锁存时 TCP 入口直接拒绝执行。"
        ]
      }
    },
    {
      "method": "move",
      "kind": "command",
      "paramsSchema": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" },
          "speed": { "type": "number" }
        },
        "additionalProperties": false
      },
      "resultSchema": {
        "type": "object",
        "required": ["moving"],
        "properties": {
          "moving": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "errorCodes": [2400, 2401, 2402, 2403, 2404],
      "consumers": [
        "hmi-client CommandProtocol.move_to",
        "Backend_CPP CLI MOVE"
      ],
      "compatibility": {
        "notes": [
          "点到点移动前要求 X/Y 轴均已回零；急停或门互锁锁存时 TCP 入口直接拒绝执行。"
        ]
      }
    }
  ]
}
