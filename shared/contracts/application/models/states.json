{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "definitions": {
    "axisStatus": {
      "type": "object",
      "required": ["position", "velocity", "enabled", "homed", "homing_state"],
      "properties": {
        "position": { "type": "number" },
        "velocity": { "type": "number" },
        "enabled": { "type": "boolean" },
        "homed": {
          "type": "boolean",
          "description": "仅当 homing_state == \"homed\" 时为 true；不再由底层运动状态枚举推导。"
        },
        "homing_state": {
          "type": "string",
          "description": "回零状态机对外权威字段。"
        }
      },
      "additionalProperties": false
    },
    "ioStatus": {
      "type": "object",
      "required": ["limit_x_pos", "limit_x_neg", "limit_y_pos", "limit_y_neg", "estop", "estop_known", "door", "door_known"],
      "properties": {
        "limit_x_pos": { "type": "boolean" },
        "limit_x_neg": { "type": "boolean" },
        "limit_y_pos": { "type": "boolean" },
        "limit_y_neg": { "type": "boolean" },
        "estop": {
          "type": "boolean",
          "description": "后端权威急停信号；优先来自运行时互锁端口，端口不可用时回退到运动状态机中的 ESTOP 状态。"
        },
        "door": {
          "type": "boolean",
          "description": "后端权威安全门信号；来自运行时互锁端口。"
        },
        "estop_known": {
          "type": "boolean",
          "description": "急停信号是否可靠可判定；仅当后端当前持有权威急停来源时为 true，断线且无有效采样时必须为 false。"
        },
        "door_known": {
          "type": "boolean",
          "description": "安全门信号是否可靠可判定；false 表示来源不可判定。"
        }
      },
      "additionalProperties": false
    },
    "effectiveInterlocks": {
      "type": "object",
      "required": [
        "estop_active",
        "estop_known",
        "door_open_active",
        "door_open_known",
        "home_boundary_x_active",
        "home_boundary_y_active",
        "positive_escape_only_axes",
        "sources"
      ],
      "properties": {
        "estop_active": { "type": "boolean" },
        "estop_known": {
          "type": "boolean",
          "description": "effective interlock 视角下急停是否可靠可判定；断线且无权威急停来源时必须为 false。"
        },
        "door_open_active": { "type": "boolean" },
        "door_open_known": { "type": "boolean" },
        "home_boundary_x_active": {
          "type": "boolean",
          "description": "X 轴 HOME 参考边界是否已生效；该字段表达控制器有效保护，不等同于原始负限位输入。"
        },
        "home_boundary_y_active": {
          "type": "boolean",
          "description": "Y 轴 HOME 参考边界是否已生效；该字段表达控制器有效保护，不等同于原始负限位输入。"
        },
        "positive_escape_only_axes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sources": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "safetyBoundaryStatus": {
      "type": "object",
      "required": [
        "state",
        "motion_permitted",
        "process_output_permitted",
        "estop_active",
        "estop_known",
        "door_open_active",
        "door_open_known",
        "interlock_latched",
        "blocking_reasons"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["safe", "blocked", "unknown"],
          "description": "软件动作准入总览，不等同功能安全认证状态。"
        },
        "motion_permitted": {
          "type": "boolean",
          "description": "常规运动动作当前是否允许执行。"
        },
        "process_output_permitted": {
          "type": "boolean",
          "description": "真实工艺输出当前是否允许执行；dry_run 或 device_mode=test 时必须为 false。"
        },
        "estop_active": { "type": "boolean" },
        "estop_known": {
          "type": "boolean",
          "description": "safety boundary 视角下急停是否可靠可判定。"
        },
        "door_open_active": { "type": "boolean" },
        "door_open_known": {
          "type": "boolean",
          "description": "safety boundary 视角下安全门是否可靠可判定。"
        },
        "interlock_latched": { "type": "boolean" },
        "blocking_reasons": {
          "type": "array",
          "items": { "type": "string" },
          "description": "阻断当前动作准入的最小原因集合；unknown 原因优先将 state 标记为 unknown。"
        }
      },
      "additionalProperties": false
    },
    "actionCapabilitiesStatus": {
      "type": "object",
      "required": [
        "motion_commands_permitted",
        "manual_output_commands_permitted",
        "manual_dispenser_pause_permitted",
        "manual_dispenser_resume_permitted",
        "active_job_present",
        "estop_reset_permitted"
      ],
      "properties": {
        "motion_commands_permitted": {
          "type": "boolean",
          "description": "后端粗粒度摘要；仅当 backend 已连接且 safety_boundary.motion_permitted 为 true 时为 true。"
        },
        "manual_output_commands_permitted": {
          "type": "boolean",
          "description": "后端粗粒度摘要；仅当 backend 已连接且 safety_boundary.process_output_permitted 为 true 时为 true，不包含 HMI 本地 pending/worker/session 门禁。"
        },
        "manual_dispenser_pause_permitted": {
          "type": "boolean",
          "description": "后端粗粒度摘要；仅当 backend 已连接、safety_boundary.process_output_permitted 为 true、无 active job 且点胶阀状态为 Running 时为 true；不包含 Timed/PositionTriggered/连续开阀模式差异，也不包含 HMI 本地 pending/worker/session 门禁。"
        },
        "manual_dispenser_resume_permitted": {
          "type": "boolean",
          "description": "后端粗粒度摘要；仅当 backend 已连接、safety_boundary.process_output_permitted 为 true、无 active job 且点胶阀状态为 Paused 时为 true；不包含 Timed/PositionTriggered/连续开阀模式差异，也不包含 HMI 本地 pending/worker/session 门禁。"
        },
        "active_job_present": {
          "type": "boolean",
          "description": "后端当前是否存在活动 job 上下文；仅基于 job_execution 派生，不等同 HMI 本地 current job。"
        },
        "estop_reset_permitted": {
          "type": "boolean",
          "description": "后端粗粒度摘要；仅当 backend 已连接且 supervision.current_state 为 Estop 时为 true，不包含底层硬件按钮释放等更细执行条件。"
        }
      },
      "additionalProperties": false
    },
    "supervisionStatus": {
      "type": "object",
      "required": [
        "current_state",
        "requested_state",
        "state_change_in_process",
        "state_reason",
        "failure_code",
        "failure_stage",
        "recoverable",
        "updated_at"
      ],
      "properties": {
        "current_state": { "type": "string" },
        "requested_state": {
          "type": "string",
          "description": "监督层当前目标状态；用于表达请求已发出但事实尚未收敛的窗口。"
        },
        "state_change_in_process": {
          "type": "boolean",
          "description": "true 表示当前处于监督态切换窗口，消费者不得将瞬时首帧误判为最终事实。"
        },
        "state_reason": { "type": "string" },
        "failure_code": { "type": "string" },
        "failure_stage": { "type": "string" },
        "recoverable": { "type": "boolean" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "runtimeIdentityStatus": {
      "type": "object",
      "required": [
        "executable_path",
        "working_directory",
        "protocol_version",
        "preview_snapshot_contract"
      ],
      "properties": {
        "executable_path": {
          "type": "string",
          "description": "当前 runtime 进程 executable 权威路径；HMI online startup gate 用它核对本地 launch contract。"
        },
        "working_directory": {
          "type": "string",
          "description": "当前 runtime 进程 working directory 权威路径；HMI online startup gate 用它核对本地 launch contract。"
        },
        "protocol_version": {
          "type": "string",
          "description": "当前 runtime 进程公开的 application protocol version；startup gate 依赖它验证协议契约。"
        },
        "preview_snapshot_contract": {
          "type": "string",
          "description": "当前 runtime 进程公开的 preview snapshot contract authority；缺失或不匹配必须 fail-closed。"
        }
      },
      "additionalProperties": false
    },
    "machineStatus": {
      "type": "object",
      "required": ["connected", "connection_state", "device_mode", "machine_state", "machine_state_reason", "supervision", "runtime_identity", "safety_boundary", "action_capabilities", "interlock_latched", "job_execution", "axes", "effective_interlocks", "io", "dispenser", "alarms"],
      "properties": {
        "connected": { "type": "boolean" },
        "connection_state": { "type": "string" },
        "device_mode": {
          "type": "string",
          "enum": ["production", "test"],
          "description": "设备模式 V1 字段；当前由运行时执行上下文单向派生：job_execution.dry_run 为 true 时为 \"test\"，其余为 \"production\"。在独立 device_mode owner 落地前，不表达 HMI 启动模式或离线模式。"
        },
        "machine_state": {
          "type": "string",
          "description": "兼容字段；语义镜像 supervision.current_state，供尚未迁移到 supervision 的调用方读取。"
        },
        "machine_state_reason": {
          "type": "string",
          "description": "兼容字段；语义镜像 supervision.state_reason，供尚未迁移到 supervision 的调用方读取。"
        },
        "interlock_latched": { "type": "boolean" },
        "job_execution": { "$ref": "#/definitions/dxfJobStatus" },
        "safety_boundary": { "$ref": "#/definitions/safetyBoundaryStatus" },
        "action_capabilities": { "$ref": "#/definitions/actionCapabilitiesStatus" },
        "axes": { "type": "object" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": false
        },
        "supervision": { "$ref": "#/definitions/supervisionStatus" },
        "runtime_identity": { "$ref": "#/definitions/runtimeIdentityStatus" },
        "effective_interlocks": { "$ref": "#/definitions/effectiveInterlocks" },
        "io": { "$ref": "#/definitions/ioStatus" },
        "dispenser": {
          "type": "object",
          "required": ["valve_open", "supply_open", "completedCount", "totalCount", "progress"],
          "properties": {
            "valve_open": { "type": "boolean" },
            "supply_open": { "type": "boolean" },
            "completedCount": {
              "type": "integer",
              "minimum": 0,
              "description": "点胶阀权威已完成触发计数；来自运行时点胶阀状态快照。"
            },
            "totalCount": {
              "type": "integer",
              "minimum": 0,
              "description": "点胶阀权威目标触发总数；来自运行时点胶阀状态快照。"
            },
            "progress": {
              "type": "number",
              "description": "点胶阀权威进度百分比，范围由运行时点胶阀状态快照给出。"
            }
          },
          "additionalProperties": false
        },
        "alarms": { "type": "array" }
      },
      "additionalProperties": false
    },
    "motionCoordAxisDiagnostics": {
      "type": "object",
      "required": [
        "position",
        "velocity",
        "state",
        "enabled",
        "homed",
        "in_position",
        "has_error",
        "error_code",
        "servo_alarm",
        "following_error",
        "home_failed",
        "hard_limit_positive",
        "hard_limit_negative",
        "soft_limit_positive",
        "soft_limit_negative",
        "home_signal",
        "index_signal",
        "selected_feedback_source",
        "prf_position_mm",
        "enc_position_mm",
        "prf_velocity_mm_s",
        "enc_velocity_mm_s",
        "prf_position_ret",
        "enc_position_ret",
        "prf_velocity_ret",
        "enc_velocity_ret"
      ],
      "properties": {
        "position": { "type": "number" },
        "velocity": { "type": "number" },
        "state": { "type": "integer" },
        "enabled": { "type": "boolean" },
        "homed": {
          "type": "boolean",
          "description": "仅当 homing_state == \"homed\" 时为 true；用于和回零状态机保持一致。"
        },
        "in_position": { "type": "boolean" },
        "has_error": { "type": "boolean" },
        "error_code": { "type": "integer" },
        "servo_alarm": { "type": "boolean" },
        "following_error": { "type": "boolean" },
        "home_failed": {
          "type": "boolean",
          "description": "原始运动控制器 HOME_FAIL 位；true 表示本轮诊断观察到回零失败锁存。"
        },
        "hard_limit_positive": { "type": "boolean" },
        "hard_limit_negative": { "type": "boolean" },
        "soft_limit_positive": { "type": "boolean" },
        "soft_limit_negative": { "type": "boolean" },
        "home_signal": { "type": "boolean" },
        "index_signal": { "type": "boolean" },
        "selected_feedback_source": {
          "type": "string",
          "enum": ["encoder", "profile"]
        },
        "prf_position_mm": { "type": "number" },
        "enc_position_mm": { "type": "number" },
        "prf_velocity_mm_s": { "type": "number" },
        "enc_velocity_mm_s": { "type": "number" },
        "prf_position_ret": { "type": "integer" },
        "enc_position_ret": { "type": "integer" },
        "prf_velocity_ret": { "type": "integer" },
        "enc_velocity_ret": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "motionCoordStatus": {
      "type": "object",
      "required": [
        "coord_sys",
        "state",
        "is_moving",
        "remaining_segments",
        "current_velocity",
        "raw_status_word",
        "raw_segment",
        "mc_status_ret"
      ],
      "properties": {
        "coord_sys": { "type": "integer" },
        "state": { "type": "integer" },
        "is_moving": { "type": "boolean" },
        "remaining_segments": { "type": "integer", "minimum": 0 },
        "current_velocity": { "type": "number" },
        "raw_status_word": { "type": "integer" },
        "raw_segment": { "type": "integer" },
        "mc_status_ret": { "type": "integer" },
        "buffer_space": { "type": "integer", "minimum": 0 },
        "lookahead_space": { "type": "integer", "minimum": 0 },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": false
        },
        "axes": {
          "type": "object",
          "required": ["X", "Y"],
          "properties": {
            "X": { "$ref": "#/definitions/motionCoordAxisDiagnostics" },
            "Y": { "$ref": "#/definitions/motionCoordAxisDiagnostics" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dxfInfo": {
      "type": "object",
      "required": ["total_length", "total_segments", "bounds"],
      "properties": {
        "total_length": { "type": "number" },
        "total_segments": { "type": "integer", "minimum": 0 },
        "bounds": {
          "type": "object",
          "required": ["x_min", "x_max", "y_min", "y_max"],
          "properties": {
            "x_min": { "type": "number" },
            "x_max": { "type": "number" },
            "y_min": { "type": "number" },
            "y_max": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dxfProgress": {
      "type": "object",
      "required": ["running", "progress", "current_segment", "total_segments", "state", "error_message"],
      "properties": {
        "running": { "type": "boolean" },
        "progress": { "type": "integer" },
        "current_segment": { "type": "integer" },
        "total_segments": { "type": "integer" },
        "state": {
          "type": "string",
          "enum": ["idle", "pending", "running", "paused", "completed", "failed", "cancelled", "unknown"]
        },
        "error_message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "dxfJobStatus": {
      "type": "object",
      "required": ["job_id", "plan_id", "plan_fingerprint", "state", "target_count", "completed_count", "current_cycle", "current_segment", "total_segments", "cycle_progress_percent", "overall_progress_percent", "elapsed_seconds", "execution_budget_s", "execution_budget_breakdown", "error_message", "dry_run"],
      "properties": {
        "job_id": { "type": "string" },
        "plan_id": { "type": "string" },
        "plan_fingerprint": { "type": "string" },
        "state": {
          "type": "string",
          "enum": ["idle", "pending", "running", "awaiting_continue", "stopping", "paused", "completed", "failed", "cancelled", "unknown"]
        },
        "target_count": { "type": "integer" },
        "completed_count": { "type": "integer" },
        "current_cycle": { "type": "integer" },
        "current_segment": { "type": "integer" },
        "total_segments": { "type": "integer" },
        "cycle_progress_percent": { "type": "integer" },
        "overall_progress_percent": { "type": "integer" },
        "elapsed_seconds": { "type": "number" },
        "execution_budget_s": { "type": "number" },
        "execution_budget_breakdown": {
          "type": "object",
          "required": ["execution_nominal_time_s", "motion_completion_grace_s", "owner_span_count", "owner_span_overhead_s", "cycle_budget_s", "target_count", "total_budget_s"],
          "properties": {
            "execution_nominal_time_s": { "type": "number" },
            "motion_completion_grace_s": { "type": "number" },
            "owner_span_count": { "type": "integer" },
            "owner_span_overhead_s": { "type": "number" },
            "cycle_budget_s": { "type": "number" },
            "target_count": { "type": "integer" },
            "total_budget_s": { "type": "number" }
          },
          "additionalProperties": false
        },
        "error_message": { "type": "string" },
        "dry_run": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "dxfJobTraceabilityExpectedItem": {
      "type": "object",
      "required": ["cycle_index", "trigger_sequence_id", "authority_trigger_index", "span_index", "component_index", "span_order_index", "source_segment_index", "execution_interpolation_index", "authority_distance_mm", "execution_profile_position_mm", "execution_position_mm", "execution_trigger_position_mm", "compare_source_axis", "compare_position_pulse", "pulse_width_us", "authority_trigger_ref", "authority_span_ref", "trigger_mode"],
      "properties": {
        "cycle_index": { "type": "integer" },
        "trigger_sequence_id": { "type": "integer" },
        "authority_trigger_index": { "type": "integer" },
        "span_index": { "type": "integer" },
        "component_index": { "type": "integer" },
        "span_order_index": { "type": "integer" },
        "source_segment_index": { "type": "integer" },
        "execution_interpolation_index": { "type": "integer" },
        "authority_distance_mm": { "type": "number" },
        "execution_profile_position_mm": { "type": "number" },
        "execution_position_mm": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": false
        },
        "execution_trigger_position_mm": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": false
        },
        "compare_source_axis": { "type": "integer" },
        "compare_position_pulse": { "type": "integer" },
        "pulse_width_us": { "type": "integer" },
        "authority_trigger_ref": { "type": "string" },
        "authority_span_ref": { "type": "string" },
        "trigger_mode": { "type": "string", "enum": ["start_boundary", "future_compare"] }
      },
      "additionalProperties": false
    },
    "dxfJobTraceabilityActualItem": {
      "type": "object",
      "required": ["cycle_index", "trigger_sequence_id", "completion_sequence", "span_index", "local_completed_trigger_count", "observed_completed_trigger_count", "compare_source_axis", "compare_position_pulse", "authority_trigger_ref", "trigger_mode"],
      "properties": {
        "cycle_index": { "type": "integer" },
        "trigger_sequence_id": { "type": "integer" },
        "completion_sequence": { "type": "integer" },
        "span_index": { "type": "integer" },
        "local_completed_trigger_count": { "type": "integer" },
        "observed_completed_trigger_count": { "type": "integer" },
        "compare_source_axis": { "type": "integer" },
        "compare_position_pulse": { "type": "integer" },
        "authority_trigger_ref": { "type": "string" },
        "trigger_mode": { "type": "string", "enum": ["start_boundary", "future_compare"] }
      },
      "additionalProperties": false
    },
    "dxfJobTraceabilityMismatch": {
      "type": "object",
      "required": ["cycle_index", "trigger_sequence_id", "code", "message"],
      "properties": {
        "cycle_index": { "type": "integer" },
        "trigger_sequence_id": { "type": "integer" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "dxfJobTraceability": {
      "type": "object",
      "required": ["job_id", "plan_id", "plan_fingerprint", "terminal_state", "expected_trace", "actual_trace", "mismatches", "verdict", "verdict_reason", "strict_one_to_one_proven"],
      "properties": {
        "job_id": { "type": "string" },
        "plan_id": { "type": "string" },
        "plan_fingerprint": { "type": "string" },
        "terminal_state": { "type": "string", "enum": ["completed", "failed", "cancelled"] },
        "expected_trace": {
          "type": "array",
          "items": { "$ref": "#/definitions/dxfJobTraceabilityExpectedItem" }
        },
        "actual_trace": {
          "type": "array",
          "items": { "$ref": "#/definitions/dxfJobTraceabilityActualItem" }
        },
        "mismatches": {
          "type": "array",
