{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "definitions": {
    "axisStatus": {
      "type": "object",
      "required": ["position", "velocity", "enabled", "homed", "homing_state"],
      "properties": {
        "position": { "type": "number" },
        "velocity": { "type": "number" },
        "enabled": { "type": "boolean" },
        "homed": {
          "type": "boolean",
          "description": "仅当 homing_state == \"homed\" 时为 true；不再由底层运动状态枚举推导。"
        },
        "homing_state": {
          "type": "string",
          "description": "回零状态机对外权威字段。"
        }
      },
      "additionalProperties": false
    },
    "ioStatus": {
      "type": "object",
      "required": ["limit_x_pos", "limit_x_neg", "limit_y_pos", "limit_y_neg", "estop", "estop_known", "door", "door_known"],
      "properties": {
        "limit_x_pos": { "type": "boolean" },
        "limit_x_neg": { "type": "boolean" },
        "limit_y_pos": { "type": "boolean" },
        "limit_y_neg": { "type": "boolean" },
        "estop": {
          "type": "boolean",
          "description": "后端权威急停信号；优先来自运行时互锁端口，端口不可用时回退到运动状态机中的 ESTOP 状态。"
        },
        "door": {
          "type": "boolean",
          "description": "后端权威安全门信号；来自运行时互锁端口。"
        },
        "estop_known": {
          "type": "boolean",
          "description": "急停信号是否可靠可判定；仅当后端当前持有权威急停来源时为 true，断线且无有效采样时必须为 false。"
        },
        "door_known": {
          "type": "boolean",
          "description": "安全门信号是否可靠可判定；false 表示来源不可判定。"
        }
      },
      "additionalProperties": false
    },
    "effectiveInterlocks": {
      "type": "object",
      "required": [
        "estop_active",
        "estop_known",
        "door_open_active",
        "door_open_known",
        "home_boundary_x_active",
        "home_boundary_y_active",
        "positive_escape_only_axes",
        "sources"
      ],
      "properties": {
        "estop_active": { "type": "boolean" },
        "estop_known": {
          "type": "boolean",
          "description": "effective interlock 视角下急停是否可靠可判定；断线且无权威急停来源时必须为 false。"
        },
        "door_open_active": { "type": "boolean" },
        "door_open_known": { "type": "boolean" },
        "home_boundary_x_active": {
          "type": "boolean",
          "description": "X 轴 HOME 参考边界是否已生效；该字段表达控制器有效保护，不等同于原始负限位输入。"
        },
        "home_boundary_y_active": {
          "type": "boolean",
          "description": "Y 轴 HOME 参考边界是否已生效；该字段表达控制器有效保护，不等同于原始负限位输入。"
        },
        "positive_escape_only_axes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sources": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "supervisionStatus": {
      "type": "object",
      "required": [
        "current_state",
        "requested_state",
        "state_change_in_process",
        "state_reason",
        "failure_code",
        "failure_stage",
        "recoverable",
        "updated_at"
      ],
      "properties": {
        "current_state": { "type": "string" },
        "requested_state": {
          "type": "string",
          "description": "监督层当前目标状态；用于表达请求已发出但事实尚未收敛的窗口。"
        },
        "state_change_in_process": {
          "type": "boolean",
          "description": "true 表示当前处于监督态切换窗口，消费者不得将瞬时首帧误判为最终事实。"
        },
        "state_reason": { "type": "string" },
        "failure_code": { "type": "string" },
        "failure_stage": { "type": "string" },
        "recoverable": { "type": "boolean" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "machineStatus": {
      "type": "object",
      "required": ["connected", "connection_state", "machine_state", "machine_state_reason", "supervision", "interlock_latched", "active_job_id", "active_job_state", "axes", "effective_interlocks", "io", "dispenser", "alarms"],
      "properties": {
        "connected": { "type": "boolean" },
        "connection_state": { "type": "string" },
        "machine_state": {
          "type": "string",
          "description": "权威状态枚举：Disconnected / Idle / Running / Paused / Interlock / Estop / Fault / Unknown。"
        },
        "machine_state_reason": { "type": "string" },
        "interlock_latched": { "type": "boolean" },
        "active_job_id": { "type": "string" },
        "active_job_state": { "type": "string" },
        "axes": { "type": "object" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": false
        },
        "supervision": { "$ref": "#/definitions/supervisionStatus" },
        "effective_interlocks": { "$ref": "#/definitions/effectiveInterlocks" },
        "io": { "$ref": "#/definitions/ioStatus" },
        "dispenser": {
          "type": "object",
          "required": ["valve_open", "supply_open"],
          "properties": {
            "valve_open": { "type": "boolean" },
            "supply_open": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "alarms": { "type": "array" }
      },
      "additionalProperties": false
    },
    "motionCoordAxisDiagnostics": {
      "type": "object",
      "required": [
        "position",
        "velocity",
        "state",
        "enabled",
        "homed",
        "in_position",
        "has_error",
        "error_code",
        "servo_alarm",
        "following_error",
        "home_failed",
        "hard_limit_positive",
        "hard_limit_negative",
        "soft_limit_positive",
        "soft_limit_negative",
        "home_signal",
        "index_signal",
        "selected_feedback_source",
        "prf_position_mm",
        "enc_position_mm",
        "prf_velocity_mm_s",
        "enc_velocity_mm_s",
        "prf_position_ret",
        "enc_position_ret",
        "prf_velocity_ret",
        "enc_velocity_ret"
      ],
      "properties": {
        "position": { "type": "number" },
        "velocity": { "type": "number" },
        "state": { "type": "integer" },
        "enabled": { "type": "boolean" },
        "homed": {
          "type": "boolean",
          "description": "仅当 homing_state == \"homed\" 时为 true；用于和回零状态机保持一致。"
        },
        "in_position": { "type": "boolean" },
        "has_error": { "type": "boolean" },
        "error_code": { "type": "integer" },
        "servo_alarm": { "type": "boolean" },
        "following_error": { "type": "boolean" },
        "home_failed": {
          "type": "boolean",
          "description": "原始运动控制器 HOME_FAIL 位；true 表示本轮诊断观察到回零失败锁存。"
        },
        "hard_limit_positive": { "type": "boolean" },
        "hard_limit_negative": { "type": "boolean" },
        "soft_limit_positive": { "type": "boolean" },
        "soft_limit_negative": { "type": "boolean" },
        "home_signal": { "type": "boolean" },
        "index_signal": { "type": "boolean" },
        "selected_feedback_source": {
          "type": "string",
          "enum": ["encoder", "profile"]
        },
        "prf_position_mm": { "type": "number" },
        "enc_position_mm": { "type": "number" },
        "prf_velocity_mm_s": { "type": "number" },
        "enc_velocity_mm_s": { "type": "number" },
        "prf_position_ret": { "type": "integer" },
        "enc_position_ret": { "type": "integer" },
        "prf_velocity_ret": { "type": "integer" },
        "enc_velocity_ret": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "motionCoordStatus": {
      "type": "object",
      "required": [
        "coord_sys",
        "state",
        "is_moving",
        "remaining_segments",
        "current_velocity",
        "raw_status_word",
        "raw_segment",
        "mc_status_ret"
      ],
      "properties": {
        "coord_sys": { "type": "integer" },
        "state": { "type": "integer" },
        "is_moving": { "type": "boolean" },
        "remaining_segments": { "type": "integer", "minimum": 0 },
        "current_velocity": { "type": "number" },
        "raw_status_word": { "type": "integer" },
        "raw_segment": { "type": "integer" },
        "mc_status_ret": { "type": "integer" },
        "buffer_space": { "type": "integer", "minimum": 0 },
        "lookahead_space": { "type": "integer", "minimum": 0 },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": false
        },
        "axes": {
          "type": "object",
          "required": ["X", "Y"],
          "properties": {
            "X": { "$ref": "#/definitions/motionCoordAxisDiagnostics" },
            "Y": { "$ref": "#/definitions/motionCoordAxisDiagnostics" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dxfInfo": {
      "type": "object",
      "required": ["total_length", "total_segments", "bounds"],
      "properties": {
        "total_length": { "type": "number" },
        "total_segments": { "type": "integer", "minimum": 0 },
        "bounds": {
          "type": "object",
          "required": ["x_min", "x_max", "y_min", "y_max"],
          "properties": {
            "x_min": { "type": "number" },
            "x_max": { "type": "number" },
            "y_min": { "type": "number" },
            "y_max": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dxfProgress": {
      "type": "object",
      "required": ["running", "progress", "current_segment", "total_segments", "state", "error_message"],
      "properties": {
        "running": { "type": "boolean" },
        "progress": { "type": "integer" },
        "current_segment": { "type": "integer" },
        "total_segments": { "type": "integer" },
        "state": {
          "type": "string",
          "enum": ["idle", "pending", "running", "paused", "completed", "failed", "cancelled", "unknown"]
        },
        "error_message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "dxfJobStatus": {
      "type": "object",
      "required": ["job_id", "plan_id", "plan_fingerprint", "state", "target_count", "completed_count", "current_cycle", "current_segment", "total_segments", "cycle_progress_percent", "overall_progress_percent", "elapsed_seconds", "error_message", "dry_run"],
      "properties": {
        "job_id": { "type": "string" },
        "plan_id": { "type": "string" },
        "plan_fingerprint": { "type": "string" },
        "state": {
          "type": "string",
          "enum": ["pending", "running", "stopping", "paused", "completed", "failed", "cancelled", "unknown"]
        },
        "target_count": { "type": "integer" },
        "completed_count": { "type": "integer" },
        "current_cycle": { "type": "integer" },
        "current_segment": { "type": "integer" },
        "total_segments": { "type": "integer" },
        "cycle_progress_percent": { "type": "integer" },
        "overall_progress_percent": { "type": "integer" },
        "elapsed_seconds": { "type": "number" },
        "error_message": { "type": "string" },
        "dry_run": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "alarm": {
      "type": "object",
      "required": ["id", "level", "message"],
      "properties": {
        "id": { "type": "string" },
        "level": { "type": "string", "enum": ["CRIT", "WARN"] },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "parameterValueEntry": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string" },
        "value": { "description": "当前序列化事实允许 bool / int / float / string。" }
      },
      "additionalProperties": false
    },
    "recipe": {
      "type": "object",
      "required": ["id", "name", "description", "status", "tags", "versionIds", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "activeVersionId": { "type": "string" },
        "versionIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "recipeVersion": {
      "type": "object",
      "required": ["id", "recipeId", "versionLabel", "status", "parameters", "createdBy", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "recipeId": { "type": "string" },
        "versionLabel": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "baseVersionId": { "type": "string" },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/definitions/parameterValueEntry" }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "integer" },
        "publishedAt": { "type": "integer" },
        "changeNote": { "type": "string" }
      },
      "additionalProperties": false
    },
    "template": {
      "type": "object",
      "required": ["id", "name", "description", "parameters", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/definitions/parameterValueEntry" }
        },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "parameterSchema": {
      "type": "object",
      "required": ["schemaId", "entries"],
      "properties": {
        "schemaId": { "type": "string" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "type", "required"],
            "properties": {
              "key": { "type": "string" },
              "displayName": { "type": "string" },
              "type": { "type": "string", "enum": ["int", "float", "bool", "string", "enum"] },
              "unit": { "type": "string" },
              "required": { "type": "boolean" },
              "constraints": { "type": "object" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "fieldChange": {
      "type": "object",
      "required": ["field"],
      "properties": {
        "field": { "type": "string" },
        "before": { "type": "string" },
        "after": { "type": "string" }
      },
      "additionalProperties": false
    },
    "auditRecord": {
      "type": "object",
      "required": ["id", "recipeId", "action", "actor", "timestamp", "changes"],
      "properties": {
        "id": { "type": "string" },
        "recipeId": { "type": "string" },
        "versionId": { "type": "string" },
        "action": { "type": "string", "enum": ["create", "edit", "publish", "rollback", "archive", "import", "export"] },
        "actor": { "type": "string" },
        "timestamp": { "type": "integer" },
        "changes": {
          "type": "array",
          "items": { "$ref": "#/definitions/fieldChange" }
        }
      },
      "additionalProperties": false
    },
    "importConflict": {
      "type": "object",
      "required": ["type", "message", "existingId", "incomingName", "suggestedResolution"],
      "properties": {
        "type": { "type": "string", "enum": ["name", "version"] },
        "message": { "type": "string" },
        "existingId": { "type": "string" },
        "incomingName": { "type": "string" },
        "suggestedResolution": { "type": "string", "enum": ["rename", "skip", "replace"] }
      },
      "additionalProperties": false
    }
  }
}
