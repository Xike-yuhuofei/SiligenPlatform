{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "protocol": "siligen.application/1.0",
  "errorEnvelopeRef": "../models/common.json#/definitions/errorEnvelope",
  "registry": [
    {
      "range": "1000-1003",
      "owner": "transport-gateway",
      "codes": [
        { "code": 1000, "name": "INVALID_JSON", "message": "Invalid JSON format" },
        { "code": 1001, "name": "MISSING_METHOD", "message": "Missing 'method' field" },
        { "code": 1002, "name": "UNKNOWN_METHOD", "messagePrefix": "Unknown method:" },
        { "code": 1003, "name": "HANDLER_ERROR", "messagePrefix": "Handler error:" }
      ]
    },
    {
      "range": "2000-3463",
      "owner": "application-adapter",
      "note": "各方法级错误码细分见 commands/*.json 与 queries/*.json。"
    }
  ]
}
